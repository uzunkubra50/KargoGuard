# KargoGuard – Docker Yapılandırma Şablonu
# Kopyalayın ve gerçek değerleri doldurun:
#   cp .env.example .env
# .env dosyası .gitignore ile korunur — repoya commit etmeyin.

# ── Veritabanı ────────────────────────────────────────────────
DB_USER=kargo_admin
DB_PASSWORD=GUCLU_SIFRE_BURAYA
DB_NAME=kargoguard_db

# ── RabbitMQ ──────────────────────────────────────────────────
RABBITMQ_USERNAME=kargo_admin
RABBITMQ_PASSWORD=GUCLU_SIFRE_BURAYA

# ── MinIO ─────────────────────────────────────────────────────
MINIO_ACCESS_KEY=kargo_admin
MINIO_SECRET_KEY=GUCLU_SIFRE_BURAYA   # en az 8 karakter
MINIO_BUCKET=kargo-images

# ── Gemini AI ─────────────────────────────────────────────────
GEMINI_API_KEY=AIzaSy...buraya_gercek_key
GEMINI_MODEL=gemini-2.5-flash

# ── Roboflow YOLO ─────────────────────────────────────────────
ROBOFLOW_API_KEY=buraya_gercek_key

# ── Blockchain (Ethereum Sepolia test ağı) ─────────────────────
BLOCKCHAIN_ALCHEMY_URL=https://eth-sepolia.g.alchemy.com/v2/ALCHEMY_KEY
BLOCKCHAIN_PRIVATE_KEY=CUZDAN_PRIVATE_KEY_64_HEX_KARAKTER
BLOCKCHAIN_CONTRACT_ADDRESS=0xCONTRACT_ADDRESS

# ── JWT Kimlik Doğrulama ───────────────────────────────────────
JWT_KEY=en_az_32_karakter_tamamen_rastgele_string

# ── Grafana ───────────────────────────────────────────────────
GRAFANA_PASSWORD=kargoguard

# ── GitHub Container Registry (Production deploy için) ─────────
GITHUB_USERNAME=github-kullanici-adiniz

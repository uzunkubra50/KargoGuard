var db = new Npgsql.NpgsqlConnection("Host=localhost;Port=5432;Database=kargoguard;Username=postgres;Password=postgres"); db.Open(); var cmd = new Npgsql.NpgsqlCommand("SELECT delivery_final_decision, delivery_ai_confidence, delivery_ai_class FROM cargo_analysis_results WHERE id=9", db); using var r = cmd.ExecuteReader(); while(r.Read()) Console.WriteLine($"[{r[0]}] | [{r[1]}] | [{r[2]}]");

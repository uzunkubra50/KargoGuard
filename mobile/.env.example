# KargoGuard API bağlantı adresi
# Seçenekler:
#   Aynı WiFi ağında  → ipconfig komutuyla IPv4 adresini bul  : http://192.168.x.x:5229
#   Ngrok tüneli      → ngrok http 5229 komutuyla al           : https://xxxx.ngrok-free.app
#   Android emülatör  → Docker ile çalışıyorsa                 : http://10.0.2.2:5229
EXPO_PUBLIC_API_URL=http://192.168.x.x:5229
